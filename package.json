{
  "name": "my-calculator",
  "version": "1.1.3",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "Joshua Alvarado",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.joshalvarado.vampyrcalc",
    "productName": "Vampyr Calc",
    "files": [
      "src/**/*",
      "main.js"
    ],
    "publish": {
      "provider": "github",
      "owner": "JoshuaAlvarado-hub",
      "repo": "vampyr-calc",
      "releaseType": "release"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "src/assets/icon.png",
      "artifactName": "Vampyr-Calc-${version}.AppImage"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png",
      "artifactName": "Vampyr-Calc-Setup-${version}.exe"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
